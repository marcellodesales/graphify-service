# graphify-service backend — environment (see docs/FEATURES-BACKEND-SERVICE.md §17)

# development | production
GRAPHIFY_ENV=development

# API/MCP bind address
GRAPHIFY_HTTP_ADDR=:8080

# Shared repository root (bind-mounted volume in Compose)
GRAPHIFY_REPOS_ROOT=/graphify-service/repos

# Auth: none | static | oidc   (Phase 1 supports none + static)
GRAPHIFY_AUTH_MODE=none
# Required when GRAPHIFY_AUTH_MODE=static:
# GRAPHIFY_API_TOKEN=replace-with-a-strong-secret

# Optional comma-separated git host allowlist, e.g. github.com,gitlab.com
GRAPHIFY_ALLOWED_GIT_HOSTS=

# Limits / timeouts
GRAPHIFY_MAX_REQUEST_BYTES=1MiB
GRAPHIFY_CLONE_TIMEOUT=10m
GRAPHIFY_RUN_TIMEOUT=60m

# Logging: debug | info | warn | error
GRAPHIFY_LOG_LEVEL=info

# MCP session mode (Phase 4)
GRAPHIFY_MCP_STATELESS=true

# Escape hatch: allow auth=none on a non-loopback bind in production (NOT recommended)
# GRAPHIFY_INSECURE_ALLOW_NO_AUTH=1
