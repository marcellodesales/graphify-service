meta {
  name: Submit repository (idempotent)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/repositories
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "githubRepoUrl": "{{sampleRepo}}"
  }
}

assert {
  res.status: eq 200
  res.body.id: eq {{refId}}
  res.body.status: eq ready
}

tests {
  test("statusUrl points at the reference", function () {
    expect(res.getBody().statusUrl).to.equal("/api/v1/repositories/" + bru.getEnvVar("refId"));
  });
}
