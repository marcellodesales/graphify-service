meta {
  name: Artifact inventory
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/v1/repositories/{{refId}}/artifacts
  body: none
  auth: none
}

assert {
  res.status: eq 200
}

tests {
  test("inventory contains the UI-ready formats", function () {
    const names = res.getBody().artifacts.map(function (a) { return a.name; });
    expect(names).to.include("graph.json");   // canonical queryable data
    expect(names).to.include("graph.html");   // interactive viewer
    expect(names).to.include("graph.graphml"); // Gephi/yEd/Cytoscape
  });
  test("no internal .graphify_* or .git files are exposed", function () {
    const names = res.getBody().artifacts.map(function (a) { return a.name; });
    names.forEach(function (n) {
      expect(n.indexOf(".")).to.not.equal(0);
    });
  });
  test("every artifact has size + sha256", function () {
    res.getBody().artifacts.forEach(function (a) {
      expect(a.size).to.be.a("number");
      expect(a.sha256).to.be.a("string").and.to.have.length(64);
    });
  });
}
